<file path="frontend/html/create-event.html">
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PlaySpot — Create Event</title>
    <link rel="stylesheet" href="../css/base.css"/>
    <link rel="stylesheet" href="../css/components.css"/>
    <link rel="stylesheet" href="../css/pages/create-event.css"/>
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css"/>
</head>
<body>
    <!-- NAVBAR -->
    <nav class="navbar">
        <a href="index.html" class="navbar-logo">
            <div class="navbar-logo-dot"></div>
            PlaySpot
        </a>

        <ul class="navbar-links">
            <li><a href="dashboard.html">Dashboard</a></li>
            <li><a href="explore.html">Explore</a></li>
            <li><a href="create-event.html" class="active">Host event</a></li>
            <li><a href="my-events.html">My events</a></li>
        </ul>

        <div class="navbar-actions">
            <a href="#" class="navbar-bell">🔔<span class="navbar-bell-dot"></span></a>
            <div class="navbar-avatar">A</div>
        </div>

        <div class="navbar-hamburger" onclick="toggleMenu()">
            <span></span><span></span><span></span>
        </div>
    </nav>

    <!-- Page Layout -->
    <div class="create-page">

        <!-- LEFT PART -->
        <div class="create-form-area">
            <h1 class="create-page-title">Host an event</h1>
            <p class="create-page-subtitle">Fill in the details and get players showing up.</p>

            <!-- Step Progress -->
            <div class="step-progress" id="step-progress">
                <div class="step-item active" data-step="1">
                    <div class="step-circle">1</div>
                    <span class="step-label">Sport & details</span>
                </div>

                <div class="step-item" data-step="2">
                    <div class="step-circle">2</div>
                    <span class="step-label">Location & time</span>
                </div>

                <div class="step-item" data-step="3">
                    <div class="step-circle">3</div>
                    <span class="step-label">Players & rules</span>
                </div>

                <div class="step-item" data-step="4">
                    <div class="step-circle">4</div>
                    <span class="step-label">Review & publish</span>
                </div>
            </div>

            <!-- STEP 1 - Sport & details -->
            <div class="form-panel active" id="step-1">
                <div>
                    <div class="form-section-title">Pick a sport</div>
                    <div class="form-section-desc">What are you playing?</div>
                    <div class="sport-selector">
                        <div class="sport-option" onclick="selectSport(this, 'Football', '⚽', 'band-football')">
                            <span class="sport-option-icon">⚽</span>
                            <span class="sport-option-name">Football</span>
                        </div>
                        <div class="sport-option" onclick="selectSport(this, 'Basketball', '🏀', 'band-basketball')">
                            <span class="sport-option-icon">🏀</span>
                            <span class="sport-option-name">Basketball</span>
                        </div>
                        <div class="sport-option" onclick="selectSport(this, 'Tennis', '🎾', 'band-tennis')">
                            <span class="sport-option-icon">🎾</span>
                            <span class="sport-option-name">Tennis</span>
                        </div>
                        <div class="sport-option" onclick="selectSport(this, 'Volleyball', '🏐', 'band-volleyball')">
                            <span class="sport-option-icon">🏐</span>
                            <span class="sport-option-name">Volleyball</span>
                        </div>
                        <div class="sport-option" onclick="selectSport(this, 'Running', '🏃', 'band-running')">
                            <span class="sport-option-icon">🏃</span>
                            <span class="sport-option-name">Running</span>
                        </div>
                        <div class="sport-option" onclick="selectSport(this, 'Cycling', '🚴', 'band-cycling')">
                            <span class="sport-option-icon">🚴</span>
                            <span class="sport-option-name">Cycling</span>
                        </div>
                        <div class="sport-option" onclick="selectSport(this, 'Swimming', '🏊', 'band-default')">
                            <span class="sport-option-icon">🏊</span>
                            <span class="sport-option-name">Swimming</span>
                        </div>
                        <div class="sport-option" onclick="selectSport(this, 'Other', '🏅', 'band-default')">
                            <span class="sport-option-icon">🏅</span>
                            <span class="sport-option-name">Other</span>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label" for="event-title">Event title</label>
                    <input class="form-input" type="text" id="event-title" placeholder="e.g. 5-a-side at Karpoš" oninput="updatePreview('title', this.value)" maxlength="60">
                    <span class="form-hint">Keep it short and descriptive.</span>
                </div>

                <div class="form-group">
                    <label class="form-label" for="event-desc">Description <span style="color:var(--muted);font-weight:300">(optional)</span></label>
                    <textarea class="form-input form-textarea" id="event-desc" placeholder="Any extra info players should know — gear needed, format, meetup point..." rows="3"></textarea>
                </div>

                <div class="form-nav">
                    <span></span>
                    <button class="btn btn-acid btn-lg" onclick="goToStep(2)">Next: Location &amp; time →</button>
                </div>
            </div>

            <!-- STEP 2 - Location & time -->
            <div class="form-panel" id="step-2">
                <div>
                    <div class="form-section-title">Where &amp; when?</div>
                    <div class="form-section-desc">Pin the location and set the date and time.</div>
                </div>

                <!-- MAP PICKER -->
                <div class="form-group">
                    <label class="form-label">Location</label>
                    <div class="map-picker">
                        <div class="map-picker-placeholder" onclick="openMapPicker()">
                            <div class="map-picker-icon">📍</div>
                            <div class="map-picker-text">Click to pin location on map</div>
                        </div>
                        <div class="map-picker-footer">
                            <span class="map-picker-address" id="selected-address">No location selected yet</span>
                            <button class="map-picker-change" onclick="openMapPicker()">Change</button>
                        </div>
                    </div>
                </div>

                <!-- Address Manual Input -->
                <div class="form-group">
                    <label class="form-label" for="event-address">Or type the address</label>
                    <input class="form-input" type="text" id="event-address" placeholder="Street, venue name, or landmark" oninput="updatePreview('location', this.value)">
                </div>

                <!-- Date & Time -->
                <div class="form-row-2">
                    <div class="form-group">
                        <label class="form-label" for="event-date">Date</label>
                        <input class="form-input" type="date" id="event-date" oninput="updatePreview('date', this.value)">
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="event-time">Start time</label>
                        <input class="form-input" type="time" id="event-time" oninput="updatePreview('time', this.value)">
                    </div>
                </div>

                <!-- Duration -->
                <div class="form-group">
                    <label class="form-label" for="event-duration">Duration</label>
                    <select class="form-input form-select" id="event-duration">
                        <option value="">Select duration</option>
                        <option value="30">30 minutes</option>
                        <option value="60">1 hour</option>
                        <option value="90">1.5 hours</option>
                        <option value="120">2 hours</option>
                        <option value="180">3 hours</option>
                        <option value="custom">Custom</option>
                    </select>
                </div>

                <div class="form-nav">
                    <button class="btn btn-ghost btn-lg" onclick="goToStep(1)">← Back</button>
                    <button class="btn btn-acid btn-lg" onclick="goToStep(3)">Next: Players &amp; rules →</button>
                </div>
            </div>

            <!-- Step 3 - Players & rules -->
            <div class="form-panel" id="step-3">
                <div>
                    <div class="form-section-title">Players &amp; rules</div>
                    <div class="form-section-desc">How many players and what level?</div>
                </div>

                <!-- Max Players Stepper -->
                <div class="form-group">
                    <label class="form-label">Maximum players</label>
                    <div class="player-stepper">
                        <button class="stepper-btn" onclick="changeCount(-1)" id="count-minus">−</button>
                        <div class="stepper-value" id="player-count">10</div>
                        <button class="stepper-btn" onclick="changeCount(1)" id="count-plus">+</button>
                    </div>
                    <span class="form-hint">Including yourself.</span>
                </div>

                <!-- Skill level -->
                <div class="form-group">
                    <label class="form-label">Skill level</label>
                    <div class="skill-selector">
                        <div class="skill-option" onclick="selectSkill(this, 'All levels')">
                            <span class="skill-option-label">All levels</span>
                            <span class="skill-option-desc">Everyone welcome</span>
                        </div>
                        <div class="skill-option" onclick="selectSkill(this, 'Beginner')">
                            <span class="skill-option-label">Beginner</span>
                            <span class="skill-option-desc">Just starting out</span>
                        </div>
                        <div class="skill-option" onclick="selectSkill(this, 'Intermediate')">
                            <span class="skill-option-label">Intermediate</span>
                            <span class="skill-option-desc">Some experience</span>
                        </div>
                        <div class="skill-option" onclick="selectSkill(this, 'Advanced')">
                            <span class="skill-option-label">Advanced</span>
                            <span class="skill-option-desc">Competitive level</span>
                        </div>
                    </div>
                </div>

                <!-- Gender -->
                <div class="form-group">
                    <label class="form-label" for="event-gender">Open to</label>
                    <select class="form-input form-select" id="event-gender">
                        <option value="all">Everyone</option>
                        <option value="male">Men only</option>
                        <option value="female">Women only</option>
                    </select>
                </div>

                <!-- Age range -->
                <div class="form-row-2">
                    <div class="form-group">
                        <label class="form-label" for="age-min">Min age</label>
                        <input class="form-input" type="number" id="age-min" placeholder="16" min="5" max="99">
                    </div>
                    <div class="form-group">
                        <label class="form-label" for="age-max">Max age</label>
                        <input class="form-input" type="number" id="age-max" placeholder="Any" min="5" max="99">
                    </div>
                </div>

                <!-- Requires approval -->
                <div class="form-group">
                    <label class="form-label">Join requires approval?</label>
                    <div style="display:flex;gap:12px;margin-top:4px;">
                         <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:14px;color:var(--muted);font-family:var(--font-body)">
                             <input type="radio" name="approval" value="open" checked style="accent-color:var(--ink)">
                             Open — anyone can join instantly
                         </label>
                    </div>
                    <div style="display:flex;gap:12px;margin-top:8px;">
                        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:14px;color:var(--muted);font-family:var(--font-body)">
                            <input type="radio" name="approval" value="approval" style="accent-color:var(--ink)">
                            Request — you approve each player
                        </label>
                    </div>
                </div>

                <div class="form-nav">
                    <button class="btn btn-ghost btn-lg" onclick="goToStep(2)">← Back</button>
                    <button class="btn btn-acid btn-lg" onclick="goToStep(4)">Next: Review →</button>
                </div>
            </div>

            <!-- Step 4 : Review and Publish -->
            <div class="form-panel" id="step-4">
                <div>
                    <div class="form-section-title">Review &amp; publish</div>
                    <div class="form-section-desc">Everything look good? Hit publish to go live.</div>
                </div>

                <!-- Summary rows -->
                <div class="card" style="display:flex;flex-direction:column;gap:14px;border-width:1px;border-color:var(--border);">
                    <div style="display:flex;justify-content:space-between;align-items:center;padding-bottom:14px;border-bottom:1px solid var(--border);">
                        <span style="font-size:13px;color:var(--muted);font-family:var(--font-body)">Sport</span>
                        <span style="font-size:14px;font-weight:500;color:var(--ink);font-family:var(--font-body)" id="review-sport">—</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;align-items:center;padding-bottom:14px;border-bottom:1px solid var(--border);">
                        <span style="font-size:13px;color:var(--muted);font-family:var(--font-body)">Title</span>
                        <span style="font-size:14px;font-weight:500;color:var(--ink);font-family:var(--font-body)" id="review-title">—</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;align-items:center;padding-bottom:14px;border-bottom:1px solid var(--border);">
                        <span style="font-size:13px;color:var(--muted);font-family:var(--font-body)">Location</span>
                        <span style="font-size:14px;font-weight:500;color:var(--ink);font-family:var(--font-body)" id="review-location">—</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;align-items:center;padding-bottom:14px;border-bottom:1px solid var(--border);">
                        <span style="font-size:13px;color:var(--muted);font-family:var(--font-body)">Date &amp; time</span>
                        <span style="font-size:14px;font-weight:500;color:var(--ink);font-family:var(--font-body)" id="review-datetime">—</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;align-items:center;padding-bottom:14px;border-bottom:1px solid var(--border);">
                        <span style="font-size:13px;color:var(--muted);font-family:var(--font-body)">Max players</span>
                        <span style="font-size:14px;font-weight:500;color:var(--ink);font-family:var(--font-body)" id="review-players">—</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;align-items:center;">
                        <span style="font-size:13px;color:var(--muted);font-family:var(--font-body)">Skill level</span>
                        <span style="font-size:14px;font-weight:500;color:var(--ink);font-family:var(--font-body)" id="review-skill">—</span>
                    </div>
                </div>

                <!-- Error message -->
                <div class="auth-error" id="publish-error">
                    Please fill in all required fields before publishing.
                </div>

                <div class="form-nav">
                    <button class="btn btn-ghost btn-lg" onclick="goToStep(3)">← Back</button>
                    <button class="btn btn-acid btn-lg" id="publish-btn" onclick="publishEvent()">
                        🚀 Publish event
                    </button>
                </div>
            </div>
        </div>

        <!-- Right : Live Preview -->
        <div class="create-preview">
            <div class="preview-label">Live preview</div>

            <div class="preview-card">
                <div class="preview-card-band band-default" id="preview-band"></div>
                <div class="preview-card-body">
                    <div class="preview-sport-badge" id="preview-sport-badge">🏅 Sport</div>
                    <div class="preview-title empty" id="preview-title">Your event title will appear here</div>
                    <hr class="preview-divider"/>
                    <div class="preview-meta-row">
                        <span class="preview-meta-icon">📅</span>
                        <span id="preview-date">Date &amp; time not set</span>
                    </div>
                    <div class="preview-meta-row">
                        <span class="preview-meta-icon">📍</span>
                        <span id="preview-location">Location not set</span>
                    </div>
                    <div class="preview-meta-row">
                        <span class="preview-meta-icon">👥</span>
                        <span id="preview-players">10 max players</span>
                    </div>
                    <div class="preview-meta-row">
                        <span class="preview-meta-icon">🎯</span>
                        <span id="preview-skill">Skill level not set</span>
                    </div>
                </div>
            </div>

            <div class="preview-tips">
                <div class="preview-tips-title">💡 Tips for a great event</div>
                <ul>
                    <li>Add a clear title so players know exactly what to expect</li>
                    <li>Include the exact entrance or meetup point in the description</li>
                    <li>Set a realistic player limit for the venue size</li>
                    <li>Mention if players need to bring their own gear</li>
                </ul>
            </div>
        </div>        
        <!-- Map Modal -->
        <div class="modal-overlay" id="map-modal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:1000; align-items:center; justify-content:center;">
            <div class="modal-content" style="background:var(--bg); width:90%; max-width:600px; border-radius:12px; overflow:hidden; display:flex; flex-direction:column; max-height:80vh;">
                <div style="padding:16px; border-bottom:1px solid var(--border); display:flex; justify-content:space-between; align-items:center;">
                    <h3 style="margin:0; font-family:var(--font-heading);">Pick Location</h3>
                    <button onclick="closeMapPicker()" style="background:none;border:none;font-size:24px;cursor:pointer;color:var(--text);">&times;</button>
                </div>
                <div id="event-map" style="width:100%; height:400px; flex-shrink:0;"></div>
                <div style="padding:16px; background:var(--bg-subtle); display:flex; justify-content:flex-end; gap:8px;">
                    <button class="btn btn-ghost" onclick="closeMapPicker()">Cancel</button>
                    <button class="btn btn-acid" onclick="confirmMapLocation()">Confirm</button>
                </div>
            </div>
        </div>

    </div>

    <!-- Scripts -->
    <script type="module" src="../javascript/core/api.js" defer></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js" defer></script>
    <script type="module" src="../javascript/core/ui.js" defer></script>
    <script src="https://unpkg.com/leaflet/dist/leaflet.js" defer></script>
    <script type="module" src="../javascript/create-event.js" defer></script>

</body>
</html>
</file>

<file path="frontend/html/dashboard.html">
<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
         <title>PlaySpot — Dashboard</title>
         <link rel="stylesheet" href="../css/base.css">
         <link rel="stylesheet" href="../css/components.css">
         <link rel="stylesheet" href="../css/pages/dashboard.css">
         <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    </head>
    <body>
        <!-- NAVBAR - loged in state -->
         <nav class="navbar">
            <a href="landing.html" class="navbar-logo">
                <div class="navbar-logo-dot"></div>
                PlaySpot
            </a>

            <ul class="navbar-links">
                <li><a href="dashboard.html" class="active">Dashboard</a></li>
                <li><a href="explore.html">Explore</a></li>
                <li><a href="create-event.html">Host event</a></li>
                <li><a href="my-events.html">My events</a></li>
            </ul>

            <div class="navbar-actions">
                <a href="#" class="navbar-bell">
                    🔔
                    <span class="navbar-bell-dot"></span>
                </a>

                <a href="create-event.html" class="btn btn-acid btn-sm">+ New event</a>
                <div class="navbar-avatar" title="My profile">A</div>
            </div>

            <div class="navbar-hamburger" onclick="toggleMenu()">
                <span></span><span></span><span></span>
            </div>
         </nav>

         <!-- FILTER BAR -->

        <div class="dashboard-filterbar">

            <!-- Sports Filter -->
             <button class="filter-chip active" onclick="setFilter(this, 'all')">
                All sports
             </button>

             <button class="filter-chip" onclick="setFilter(this, 'football')">
                <span class="filter-chip-icon">⚽</span> Football
             </button>

             <button class="filter-chip" onclick="setFilter(this, 'basketball')">
                <span class="filter-chip-icon">🏀</span> Basketball
             </button>

             <button class="filter-chip" onclick="setFilter(this, 'tennis')">
                <span class="filter-chip-icon">🎾</span> Tennis
             </button>

             <button class="filter-chip" onclick="setFilter(this, 'volleyball')">
                <span class="filter-chip-icon">🏐</span> Volleyball
             </button>

             <button class="filter-chip" onclick="setFilter(this, 'running')">
                <span class="filter-chip-icon">🏃</span> Running
             </button>

             <button class="filter-chip" onclick="setFilter(this, 'cycling')">
                <span class="filter-chip-icon">🚴</span> Cycling
             </button>

             <div class="filter-divider"></div>

             <!-- DATE FILTER -->

             <select class="filter-select" onchange="setDateFilter(this.value)">
                <option value="today">Today</option>
                <option value="tomorrow">Tomorrow</option>
                <option value="week">This week</option>
                <option value="all">Any date</option>
             </select>
        </div>

        <!-- MAIN BODY - sidebar + map -->
        
        <div class="dashboard-page">
            <div class="dashboard-body">

                <!-- Left sidebar -->
                <aside class="dashboard-sidebar">
                    <div class="sidebar-header">
                        <div class="sidebar-title">Nearby events</div>
                        <div class="sidebar-count" id="event-count">Loading...</div>
                    </div>

                    <!-- SEARCH -->
                    <div class="sidebar-search">
                        <div class="sidebar-search-wrap">
                            <span class="sidebar-search-icon">🔍</span>
                            <input class="sidebar-search-input" type="text" placeholder="Search events..." oninput="handleSearch(this.value)">
                        </div>
                    </div>

                    <!-- Event list -->

                    <div class="sidebar-list" id="event-list">
                        <!-- Populated dynamically by api.js -->
                        <div class="loading-placeholder" style="text-align:center;padding:40px 20px;opacity:.5;">Loading events...</div>
                    </div>
                </aside>

                <!-- MAP PANEL -->

                <div class="dashboard-map" id="map-container">

                    <!-- Placeholder grid — replaced by real map via api.js + Leaflet -->

                    <div class="map-placeholder">
                        <div class="map-placeholder-icon">🗺️</div>
                        <div class="map-placeholder-text">Map loads here via Leaflet.js</div>
                    </div>

                    <!-- Map pins populated dynamically -->

                    <!-- Map Control -->

                    <div class="map-controls">
                        <button class="map-control-btn" title="Zoom in">+</button>
                        <button class="map-control-btn" title="Zoom out">−</button>
                    </div>

                    <!-- Locate Me -->

                    <button class="map-locate-btn" onclick="locateMe()">
                        📍 Near me
                    </button>
                </div>
            </div>
        </div>


        <!-- Scripts -->

        <script type="module" src="../javascript/core/api.js" defer></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js" defer></script>
        <script type="module" src="../javascript/core/ui.js" defer></script>
        <script src="https://unpkg.com/leaflet/dist/leaflet.js" defer></script>
        <script type="module" src="../javascript/pages/dashboard.js" defer></script>
        <script type="module" src="../javascript/auth.js" defer></script>
    </body>
</html>
</file>

<file path="frontend/html/event-detail.html">
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>PlaySpot - Event Details</title>
    <link rel="stylesheet" href="../css/base.css" />
    <link rel="stylesheet" href="../css/components.css" />
    <link rel="stylesheet" href="../css/pages/event-detail.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
  </head>
  <body>
    <!-- =========================NAVBAR ========================== -->
    <nav class="navbar">
      <a href="index.html" class="navbar-logo">
        <div class="navbar-logo-dot"></div>
        PlaySpot
      </a>

      <ul class="navbar-links">
        <li><a href="dashboard.html">Dashboard</a></li>
        <li><a href="explore.html">Explore</a></li>
        <li><a href="create-event.html">Host event</a></li>
        <li><a href="my-events.html">My events</a></li>
      </ul>

      <div class="navbar-actions">
        <a href="#" class="navbar-bell"
          >🔔<span class="navbar-bell-dot"></span
        ></a>
        <a href="create-event.html" class="btn btn-acid btn-sm">+ New event</a>
        <div class="navbar-avatar"></div>
      </div>

      <div class="navbar-hamburger" onclick="toggleMenu()">
        <span></span><span></span><span></span>
      </div>
    </nav>

    <div class="detail-page">
      <!-- =================HERO================== -->
      <div class="detail-hero" data-sport-icon="⚽">
        <div class="detail-hero-inner">
          <a href="explore.html" class="detail-back">← Back to events</a>
          <div class="detail-sport-badge">⚽ Football</div>
          <h1 class="detail-title">5-a-side<br />at Karpoš</h1>
          <div class="detail-meta-strip">
            <div class="detail-meta-item">
              <span class="detail-meta-icon">📅</span>
              <span
                ><span class="detail-meta-value"></span> ·
                <span class="detail-meta-value"></span
              ></span>
            </div>
            <div class="detail-meta-item">
              <span class="detail-meta-icon">⏱</span>
              <span>Duration: <span class="detail-meta-value"></span></span>
            </div>
            <div class="detail-meta-item">
              <span class="detail-meta-icon">📍</span>
              <span
                ><span class="detail-meta-value"></span>,
                <span class="detail-meta-value"></span
              ></span>
            </div>
            <div class="detail-meta-item">
              <span class="detail-meta-icon">🎯</span>
              <span>Level: <span class="detail-meta-value"></span></span>
            </div>
            <div class="detail-meta-item">
              <span class="detail-meta-icon">👥</span>
              <span
                ><span class="detail-meta-value"></span> /
                <span class="detail-meta-value"></span> players</span
              >
            </div>
          </div>
        </div>
        <div class="detail-hero-band hero-band-football"></div>
      </div>

      <!-- ============================= MAIN BODY ============================= -->
      <div class="detail-body">
        <!-- LEFT COLUMN -->
        <div class="detail-left">
          <!-- About -->
          <div class="detail-section">
            <div class="detail-section-title">About this event</div>
            <p class="detail-desc">Loading description...</p>
          </div>

          <!-- Attendees -->
          <div class="detail-section">
            <div class="detail-section-title">Players (8 / 10)</div>

            <div class="attendees-grid">
              <!-- Populated dynamically by api.js -->
            </div>

            <!-- Empty spots -->
            <div class="spots-grid">
                <!-- Populated dynamically by api.js -->
            </div>
          </div>

          <!-- Pending Join Requests (Visible only to Host) -->
          <div
            class="detail-section"
            id="host-requests-section"
            style="display: none"
          >
            <div class="detail-section-title">Pending Requests</div>
            <div
              id="host-requests-list"
              style="display: flex; flex-direction: column; gap: 12px"
            ></div>
          </div>

          <!-- Location -->
          <div class="detail-section">
            <div class="detail-section-title">Location</div>

            <!-- Map placeholder — Leaflet initialized by api.js -->

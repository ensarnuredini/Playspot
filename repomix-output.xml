  width: 10px;
  height: 10px;
  background: var(--acid);
  border-radius: 50%;
  border: 1.5px solid var(--acid);
  flex-shrink: 0;
}

.auth-left-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 48px 0;
}

.auth-left-title {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: clamp(48px, 5vw, 72px);
  text-transform: uppercase;
  letter-spacing: -2px;
  line-height: .92;
  color: var(--dark-text);
  margin-bottom: 24px;
}

.auth-left-title span {
  color: var(--acid);
}

.auth-left-desc {
  font-size: 16px;
  font-weight: 300;
  color: rgba(245,242,235,.6);
  line-height: 1.65;
  max-width: 340px;
  margin-bottom: 40px;
}

/* Mini event preview cards on left panel */
.auth-preview-cards {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.auth-preview-card {
  display: flex;
  align-items: center;
  gap: 14px;
  background: rgba(255,255,255,.06);
  border: 1px solid rgba(255,255,255,.1);
  border-radius: var(--radius-sm);
  padding: 12px 16px;
  transition: background var(--ease);
}

.auth-preview-card:hover { 
    background: rgba(255,255,255,.1); 
}

.auth-preview-icon {
  font-size: 22px;
  line-height: 1;
  flex-shrink: 0;
}

.auth-preview-info {
  flex: 1;
}

.auth-preview-title {
  font-size: 13px;
  font-weight: 500;
  color: var(--dark-text);
  margin-bottom: 2px;
}

.auth-preview-meta {
  font-size: 11px;
  color: rgba(245,242,235,.45);
  font-weight: 300;
}

.auth-preview-badge {
  background: var(--acid);
  color: var(--ink);
  font-size: 10px;
  font-weight: 700;
  padding: 3px 8px;
  border-radius: var(--radius-pill);
  text-transform: uppercase;
  letter-spacing: .04em;
  flex-shrink: 0;
}

.auth-left-footer {
  font-size: 12px;
  color: rgba(245,242,235,.3);
  font-weight: 300;
}


/* RIGHT SIDE PANEL */

.auth-right {
  background: var(--paper);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64px 48px;
  overflow-y: auto;
}

.auth-form-wrap {
  width: 100%;
  max-width: 400px;
}

.auth-tabs {
  display: flex;
  border: 1.5px solid var(--ink);
  border-radius: var(--radius-pill);
  overflow: hidden;
  margin-bottom: 40px;
}

.auth-tab {
  flex: 1;
  padding: 10px;
  text-align: center;
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  transition: all var(--ease);
  border: none;
  background: transparent;
  color: var(--muted);
  font-family: var(--font-body);
}

.auth-tab.active {
  background: var(--ink);
  color: var(--acid);
}

/* FORM PANEL */

.auth-panel { 
  display: none; 
}

.auth-panel.active { 
  display: block; 
  animation: fadeIn .3s ease both; 
}

.auth-form-title {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 32px;
  text-transform: uppercase;
  letter-spacing: -1px;
  color: var(--ink);
  margin-bottom: 6px;
}

.auth-form-subtitle {
  font-size: 14px;
  color: var(--muted);
  font-weight: 300;
  margin-bottom: 32px;
}

/* FORM LAYOUT */

.auth-form {
  display: flex;
  flex-direction: column;
  gap: 18px;
}

.auth-form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

.auth-divider {
  display: flex;
  align-items: center;
  gap: 12px;
  margin: 4px 0;
}

.auth-divider::before,
.auth-divider::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--border);
}


.auth-divider span {
  font-size: 12px;
  color: var(--muted);
  font-weight: 400;
  white-space: nowrap;
}

/* Social Login Buttons */

.auth-social-btn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  padding: 11px;
  border: 1.5px solid var(--border);
  border-radius: var(--radius-sm);
  background: var(--white);
  font-size: 14px;
  font-weight: 500;
  color: var(--ink);
  cursor: pointer;
  transition: border-color var(--ease);
  font-family: var(--font-body);
}

.auth-social-btn:hover { 
  border-color: var(--ink); 
}

.auth-forgot {
  font-size: 12px;
  color: var(--muted);
  text-decoration: none;
  text-align: right;
  display: block;
  margin-top: -8px;
  transition: color var(--ease);
}

.auth-forgot:hover { 
  color: var(--ink); 
}

/* Terms Text */

.auth-terms {
  font-size: 12px;
  color: var(--muted);
  text-align: center;
  font-weight: 300;
  line-height: 1.6;
}

.auth-terms a {
  color: var(--ink);
  text-decoration: underline;
  text-underline-offset: 2px;
}

/* Error Message Box */

.auth-error {
  background: var(--danger-bg);
  border: 1px solid var(--danger);
  border-radius: var(--radius-sm);
  padding: 10px 14px;
  font-size: 13px;
  color: var(--danger);
  display: none;
}

.auth-error.visible { 
  display: block; 
  animation: fadeIn .2s ease both; 
}

/* RESPONSIVE */

@media (max-width: 768px) {
  .auth-page {
    grid-template-columns: 1fr;
  }
  .auth-left {
    display: none;
  }
  .auth-right {
    padding: 48px 24px;
    justify-content: flex-start;
    padding-top: 64px;
  }
  .auth-form-row {
    grid-template-columns: 1fr;
  }
}
</file>

<file path="frontend/css/pages/create-event.css">
/* CREATE-EVENT.CSS — Create event page styles */

/* ── PAGE LAYOUT ── */
.create-page {
  padding-top: var(--nav-h);
  min-height: 100vh;
  display: grid;
  grid-template-columns: 1fr 380px;
  max-width: var(--max-w);
  margin: 0 auto;
  padding-left: var(--side-pad);
  padding-right: var(--side-pad);
  padding-bottom: 80px;
  gap: 64px;
  align-items: start;
}

/* ── LEFT: FORM AREA ── */
.create-form-area {
  padding-top: 48px;
}

/* Page title */
.create-page-title {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: clamp(36px, 4vw, 56px);
  text-transform: uppercase;
  letter-spacing: -1px;
  line-height: 1;
  color: var(--ink);
  margin-bottom: 8px;
}

.create-page-subtitle {
  font-size: 15px;
  color: var(--muted);
  font-weight: 300;
  margin-bottom: 40px;
}

/* ── STEP PROGRESS BAR ── */
.step-progress {
  display: flex;
  align-items: center;
  gap: 0;
  margin-bottom: 48px;
}

.step-item {
  display: flex;
  align-items: center;
  gap: 10px;
  flex: 1;
  position: relative;
}

.step-item:not(:last-child)::after {
  content: '';
  flex: 1;
  height: 2px;
  background: var(--border);
  margin: 0 8px;
  transition: background var(--ease);
}

.step-item.completed:not(:last-child)::after {
  background: var(--ink);
}

.step-circle {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  border: 2px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  font-weight: 600;
  color: var(--muted);
  background: var(--paper);
  transition: all var(--ease);
  flex-shrink: 0;
  font-family: var(--font-body);
  cursor: pointer;
}

.step-item.active .step-circle {
  border-color: var(--ink);
  background: var(--ink);
  color: var(--acid);
}

.step-item.completed .step-circle {
  border-color: var(--ink);
  background: var(--ink);
  color: var(--acid);
}

.step-label {
  font-size: 12px;
  font-weight: 500;
  color: var(--muted);
  white-space: nowrap;
  font-family: var(--font-body);
  transition: color var(--ease);
}

.step-item.active .step-label,
.step-item.completed .step-label { color: var(--ink); }

/* ── FORM PANELS ── */
.form-panel {
    display: none; 
}

.form-panel.active {
  display: flex;
  flex-direction: column;
  gap: 24px;
  animation: fadeIn .3s ease both;
}

/* Form section header */
.form-section-title {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 26px;
  text-transform: uppercase;
  letter-spacing: -.5px;
  color: var(--ink);
  margin-bottom: 4px;
}

.form-section-desc {
  font-size: 14px;
  color: var(--muted);
  font-weight: 300;
  margin-bottom: 8px;
}

/* Two-column row */
.form-row-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

.form-row-3 {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16px;
}

/* ── SPORT SELECTOR — big icon grid ── */
.sport-selector {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10px;
}

.sport-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  padding: 16px 10px;
  border: 1.5px solid var(--border);
  border-radius: var(--radius-md);
  cursor: pointer;
  transition: all var(--ease);
  background: var(--white);
  font-family: var(--font-body);
}

.sport-option:hover {
  border-color: var(--ink);
  transform: translateY(-2px);
}

.sport-option.selected {
  border-color: var(--ink);
  border-width: 2px;
  background: var(--acid);
  box-shadow: var(--shadow-sm);
}

.sport-option-icon { 
    font-size: 28px; 
    line-height: 1; 
}

.sport-option-name {
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: .04em;
  color: var(--muted);
  text-align: center;
}

.sport-option.selected .sport-option-name { 
    color: var(--ink); 
}

/* ── SKILL LEVEL SELECTOR ── */
.skill-selector {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10px;
}

.skill-option {
  padding: 14px 10px;
  border: 1.5px solid var(--border);
  border-radius: var(--radius-md);
  cursor: pointer;
  transition: all var(--ease);
  text-align: center;
  background: var(--white);
  font-family: var(--font-body);
}

.skill-option:hover { 
    border-color: var(--ink); 
}

.skill-option.selected {
  border-color: var(--ink);
  border-width: 2px;
  background: var(--ink);
}

.skill-option-label {
  font-size: 12px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: .04em;
  color: var(--muted);
  display: block;
  margin-bottom: 4px;
}

.skill-option.selected .skill-option-label { 
    color: var(--acid); 
}

.skill-option-desc {
  font-size: 11px;
  color: var(--muted);
  font-weight: 300;
}

.skill-option.selected .skill-option-desc { 
    color: rgba(200,255,0,.7); 
}

/* ── MAP LOCATION PICKER ── */
.map-picker {
  border: 1.5px solid var(--border);
  border-radius: var(--radius-md);
  overflow: hidden;
  transition: border-color var(--ease);
}

.map-picker:hover { 
    border-color: var(--ink); 
}

.map-picker-placeholder {
  height: 220px;
  background:
    linear-gradient(rgba(13,13,13,.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(13,13,13,.03) 1px, transparent 1px);
  background-size: 32px 32px;
  background-color: #eceae3;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10px;
  cursor: pointer;
}

.map-picker-placeholder:hover { 
    background-color: #e6e2da; 
}

.map-picker-icon { 
    font-size: 36px; 
    opacity: .4; 
}

.map-picker-text {
  font-size: 13px;
  color: var(--muted);
  font-weight: 300;
}

.map-picker-footer {
  padding: 12px 14px;
  border-top: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--white);
}

.map-picker-address {
  font-size: 13px;
  color: var(--muted);
  font-weight: 300;
  font-style: italic;
}

.map-picker-change {
  font-size: 12px;
  color: var(--ink);
  font-weight: 500;
  cursor: pointer;
  text-decoration: underline;
  text-underline-offset: 2px;
  background: none;
  border: none;
  font-family: var(--font-body);
}

/* ── PLAYER COUNT STEPPER ── */
.player-stepper {
  display: flex;
  align-items: center;
  gap: 0;
  border: 1.5px solid var(--border);
  border-radius: var(--radius-sm);
  overflow: hidden;
  width: fit-content;
  transition: border-color var(--ease);
}

.player-stepper:hover { 
    border-color: var(--ink); 
}

.stepper-btn {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  font-weight: 300;
  cursor: pointer;
  transition: background var(--ease);
  border: none;
  background: var(--white);
  color: var(--ink);
  font-family: var(--font-body);
}

.stepper-btn:hover { 
    background: var(--acid); 
}

.stepper-btn:disabled { 
    opacity: .3; 
    cursor: not-allowed; 
}

.stepper-value {
  min-width: 56px;
  text-align: center;
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 22px;
  color: var(--ink);
  border-left: 1px solid var(--border);
  border-right: 1px solid var(--border);
  padding: 0 12px;
  line-height: 44px;
}

/* ── FORM NAVIGATION BUTTONS ── */
.form-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 8px;
  margin-top: 8px;
  border-top: 1px solid var(--border);
}

/* ── RIGHT: PREVIEW CARD ── */
.create-preview {
  padding-top: 48px;
  position: sticky;
  top: calc(var(--nav-h) + 24px);
}

.preview-label {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 16px;
  font-family: var(--font-body);
}

.preview-card {
  background: var(--white);
  border: 2px solid var(--ink);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

.preview-card-band {
  height: 6px;
  background: var(--acid);
  transition: background .3s ease;
}

.preview-card-body {
  padding: 24px;
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.preview-sport-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: var(--acid);
  border: 1px solid var(--ink);
  border-radius: var(--radius-pill);
  padding: 4px 12px;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .06em;
  width: fit-content;
}

.preview-title {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 24px;
  text-transform: uppercase;
  letter-spacing: -.5px;
  color: var(--ink);
  line-height: 1.1;
  min-height: 28px;
}

.preview-title.empty { 
    color: var(--muted); 
    font-weight: 400; 
    font-size: 16px; 
    text-transform: none; 
    font-family: var(--font-body); 
}

.preview-meta-row {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  color: var(--muted);
  font-weight: 300;
}

.preview-meta-icon { 
    font-size: 13px; 
    flex-shrink: 0; 
}

.preview-divider {
  border: none;
  border-top: 1px solid var(--border);
}

.preview-tips {
  margin-top: 20px;
  padding: 16px;
  background: var(--info-bg);
  border: 1px solid var(--info);
  border-radius: var(--radius-sm);
}

.preview-tips-title {
  font-size: 12px;
  font-weight: 600;
  color: var(--info);
  text-transform: uppercase;
  letter-spacing: .06em;
  margin-bottom: 8px;
  font-family: var(--font-body);
}

.preview-tips ul {
  list-style: disc;
  padding-left: 16px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.preview-tips li {
  font-size: 12px;
  color: var(--info);
  font-weight: 300;
  line-height: 1.5;
}

/* Responsive */

@media (max-width: 1024px) {
  .create-page {
    grid-template-columns: 1fr;
    gap: 0;
  }
  .create-preview { display: none; }
  .sport-selector { grid-template-columns: repeat(4, 1fr); }
}

@media (max-width: 768px) {
  .create-page { padding-top: calc(var(--nav-h) + 24px); }
  .sport-selector { grid-template-columns: repeat(3, 1fr); }
  .skill-selector { grid-template-columns: repeat(2, 1fr); }
  .form-row-2, .form-row-3 { grid-template-columns: 1fr; }
  .step-label { display: none; }
}
</file>

<file path="frontend/css/pages/dashboard.css">
/* Dashboard.CSS --> Main dashboard page styles */

.dashboard-page {
  padding-top: var(--nav-h);
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.dashboard-filterbar {
  margin-top: var(--nav-h);
  border-bottom: 1px solid var(--border);
  padding: 12px var(--side-pad);
  display: flex;
  align-items: center;
  gap: 12px;
  background: var(--paper);
  overflow-x: auto;
  scrollbar-width: none;
  flex-shrink: 0;
}

.dashboard-filterbar::-webkit-scrollbar {
  display: none;
}

.sport-filters-row {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-shrink: 0;
}

/* Sport filter chips */

.filter-chip {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 7px 16px;
  border: 1.5px solid var(--border);
  border-radius: var(--radius-pill);
  font-size: 13px;
  font-weight: 500;
  color: var(--muted);
  cursor: pointer;
  white-space: nowrap;
  transition: all var(--ease);
  background: var(--paper);
  font-family: var(--font-body);
}

.filter-chip:hover {
  border-color: var(--ink);
  color: var(--ink);
}

.filter-chip.active {
  background: var(--ink);
  border-color: var(--ink);
  color: var(--acid);
}

.filter-chip-icon {
  font-size: 14px;
  line-height: 1;
}

/* Date filter select */

.filter-select {
  padding: 7px 14px;
  border: 1.5px solid var(--border);
  border-radius: var(--radius-pill);
  font-size: 13px;
  font-weight: 500;
  color: var(--ink);
  background: var(--paper);
  cursor: pointer;
  outline: none;
  transition: border-color var(--ease);
  font-family: var(--font-body);
  flex-shrink: 0;
}

.filter-select:hover,
.filter-select:focus {
  border-color: var(--ink);
}

.filter-divider {
  width: 1px;
  height: 24px;
  background: var(--border);
  flex-shrink: 0;
}

/* ── MAIN CONTENT AREA ── */

.dashboard-body {
  display: grid;
  grid-template-columns: 420px 1fr;
  flex: 1;
  overflow: hidden;
}

/* ── LEFT SIDEBAR — event list ── */

.dashboard-sidebar {
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: var(--paper);
}

.sidebar-header {
  padding: 20px 24px 14px;
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}

.sidebar-title {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 22px;
  text-transform: uppercase;
  letter-spacing: -0.5px;
  color: var(--ink);
  margin-bottom: 4px;
}

.sidebar-count {
  font-size: 13px;
  color: var(--muted);
  font-weight: 300;
}

/* Search bar inside sidebar */

.sidebar-search {
  padding: 14px 24px;
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}

.sidebar-search-input {
  width: 100%;
  padding: 9px 14px 9px 36px;
  border: 1.5px solid var(--border);
  border-radius: var(--radius-pill);
  font-size: 13px;
  background: var(--white);
  color: var(--ink);
  outline: none;
  transition: border-color var(--ease);
  font-family: var(--font-body);
  position: relative;
}

.sidebar-search-input:focus {
  border-color: var(--ink);
}

.sidebar-search-wrap {
  position: relative;
}

.sidebar-search-icon {
  position: absolute;
  left: 12px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 14px;
  color: var(--muted);
  pointer-events: none;
}

/* Scrollable event list */
.sidebar-list {
  flex: 1;
  overflow-y: auto;
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  scrollbar-width: thin;
  scrollbar-color: var(--border) transparent;
}

/* Dashboard event card — compact version */
.dash-event-card {
  background: var(--white);
  border: 1.5px solid var(--border);
  border-radius: var(--radius-md);
  padding: 16px;
  cursor: pointer;
  transition: all var(--ease);
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.dash-event-card:hover {
  border-color: var(--ink);
  transform: translateX(3px);
}

.dash-event-card.selected {
  border-color: var(--ink);
  border-width: 2px;
  box-shadow: var(--shadow-sm);
}

.dash-event-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 10px;
}

.dash-event-sport {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: var(--acid);
  border: 1px solid var(--ink);
  border-radius: var(--radius-pill);
  padding: 3px 10px;
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  white-space: nowrap;
}

.dash-event-distance {
  font-size: 11px;
  color: var(--muted);
  font-weight: 400;
  white-space: nowrap;
  flex-shrink: 0;
}

.dash-event-title {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 17px;
  text-transform: uppercase;
  letter-spacing: -0.3px;
  color: var(--ink);
  line-height: 1.1;
}

.dash-event-meta {
  display: flex;
  flex-direction: column;
  gap: 3px;
}

.dash-event-meta-row {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  color: var(--muted);
  font-weight: 300;
}

.dash-event-meta-icon {
  font-size: 12px;
  flex-shrink: 0;
}

.dash-event-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 8px;
  border-top: 1px solid var(--border);
}

.dash-spots {
  font-size: 12px;
  color: var(--muted);
}

.dash-spots strong {
  color: var(--ink);
  font-weight: 600;
}

.dash-spots.urgent strong {
  color: var(--danger);
}

/* ── RIGHT PANEL — map ── */
.dashboard-map {
  position: relative;
  background: #e8e4de;
  overflow: hidden;
}

/* Placeholder map (real map via Leaflet/Google Maps in api.js) */
.map-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 16px;
  background:
    linear-gradient(rgba(13, 13, 13, 0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(13, 13, 13, 0.03) 1px, transparent 1px);
  background-size: 40px 40px;
  background-color: #eceae3;
}

.map-placeholder-icon {
  font-size: 48px;
  opacity: 0.3;
}

.map-placeholder-text {
  font-size: 14px;
  color: var(--muted);
  font-weight: 300;
}

/* Map overlay controls */
.map-controls {
  position: absolute;
  top: 16px;
  right: 16px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.map-control-btn {
  width: 36px;
  height: 36px;
  background: var(--white);
  border: 1.5px solid var(--ink);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  cursor: pointer;
  transition: all var(--ease);
  box-shadow: var(--shadow-sm);
}

.map-control-btn:hover {
  background: var(--acid);
}

/* Locate me button */
.map-locate-btn {
  position: absolute;
  bottom: 24px;
  right: 16px;
  display: flex;
  align-items: center;
  gap: 8px;
  background: var(--white);
  border: 1.5px solid var(--ink);
  border-radius: var(--radius-pill);
  padding: 10px 18px;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  box-shadow: var(--shadow-sm);
  transition: all var(--ease);
  font-family: var(--font-body);
  color: var(--ink);
}

.map-locate-btn:hover {
  background: var(--acid);
}

/* ── UPCOMING STRIP (below map on mobile) ── */
.dashboard-upcoming {
  display: none;
}

/* RESPONSIVE */

@media (max-width: 1024px) {
  .dashboard-body {
    grid-template-columns: 340px 1fr;
  }
}

@media (max-width: 768px) {
  .dashboard-page {
    height: auto;
    overflow: auto;
  }

  .dashboard-body {
    grid-template-columns: 1fr;
    overflow: visible;
  }

  .dashboard-map {
    height: 340px;
    order: -1;
  }

  .dashboard-sidebar {
    border-right: none;
    border-top: 1px solid var(--border);
    overflow: visible;
    max-height: none;
  }

  .sidebar-list {
    overflow: visible;
    max-height: none;
  }
}
</file>

<file path="frontend/css/pages/event-detail.css">
/* EVENT-DETAIL.CSS — Event detail page styles */

/* ── PAGE LAYOUT ── */
.detail-page {
  padding-top: var(--nav-h);
  min-height: 100vh;
}

/* ── HERO BAND ── */
.detail-hero {
  background: var(--ink);
  padding: 48px var(--side-pad) 0;
  position: relative;
  overflow: hidden;
}

/* Large sport icon watermark */
.detail-hero::before {
  content: attr(data-sport-icon);
  position: absolute;
  font-size: 320px;
  line-height: 1;
  right: 80px;
  top: -40px;
  opacity: .06;
  pointer-events: none;
  user-select: none;
}

.detail-hero-inner {
  max-width: var(--max-w);
  margin: 0 auto;
}

/* Back link */
.detail-back {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  color: rgba(245,242,235,.5);
  text-decoration: none;
  margin-bottom: 24px;
  transition: color var(--ease);
  font-family: var(--font-body);
}

.detail-back:hover { color: var(--dark-text); }

/* Sport badge */
.detail-sport-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--acid);
  border: 1px solid var(--acid);
  border-radius: var(--radius-pill);
  padding: 5px 14px;
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .06em;
  color: var(--ink);
  margin-bottom: 16px;
}

/* Event title */
.detail-title {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: clamp(40px, 6vw, 80px);
  text-transform: uppercase;
  letter-spacing: -2px;
  line-height: .92;
  color: var(--dark-text);
  margin-bottom: 28px;
  max-width: 800px;
}

/* Meta strip */
.detail-meta-strip {
  display: flex;
  align-items: center;
  gap: 28px;
  flex-wrap: wrap;
  padding-bottom: 32px;
  border-bottom: 1px solid rgba(245,242,235,.1);
}

.detail-meta-item {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 14px;
  color: rgba(245,242,235,.7);
  font-weight: 300;
  font-family: var(--font-body);
}

.detail-meta-icon { 
    font-size: 16px; 
    flex-shrink: 0; 
}

.detail-meta-value { 
    color: var(--dark-text); 
    font-weight: 500; 
}

/* Colored bottom band */
.detail-hero-band {
  height: 6px;
  background: var(--acid);
  margin-top: 0;
}

.hero-band-football   { background: #3b8f5e; }
.hero-band-basketball { background: #e67e22; }
.hero-band-tennis     { background: #2ecc71; }
.hero-band-running    { background: #e74c3c; }
.hero-band-volleyball { background: #9b59b6; }
.hero-band-cycling    { background: #3498db; }

/* ── MAIN BODY ── */
.detail-body {
  max-width: var(--max-w);
  margin: 0 auto;
  padding: 48px var(--side-pad) 80px;
  display: grid;
  grid-template-columns: 1fr 360px;
  gap: 64px;
  align-items: start;
}

/* ── LEFT COLUMN ── */
.detail-left {
  display: flex;
  flex-direction: column;
  gap: 48px;
}

/* Section block */

.detail-section-title {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 22px;
  text-transform: uppercase;
  letter-spacing: -.3px;
  color: var(--ink);
  margin-bottom: 16px;
  padding-bottom: 12px;
  border-bottom: 1.5px solid var(--ink);
}

/* Description text */
.detail-desc {
  font-size: 15px;
  color: var(--muted);
  font-weight: 300;
  line-height: 1.75;
}

/* ── ATTENDEES GRID ── */
.attendees-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.attendee-card {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 14px;
  background: var(--white);
  border: 1.5px solid var(--border);
  border-radius: var(--radius-pill);
  transition: all var(--ease);
  cursor: pointer;
}

.attendee-card:hover {
  border-color: var(--ink);
  transform: translateY(-2px);
}

.attendee-card.host {
  border-color: var(--ink);
  background: var(--ink);
}

.attendee-avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  font-weight: 600;
  color: var(--white);
  text-transform: uppercase;
  flex-shrink: 0;
}

.attendee-name {
  font-size: 13px;
  font-weight: 500;
  color: var(--ink);
  font-family: var(--font-body);
}

.attendee-card.host .attendee-name { color: var(--acid); }

.attendee-role {
  font-size: 10px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: .06em;
  color: var(--acid);
  background: rgba(200,255,0,.15);
  padding: 2px 6px;
  border-radius: var(--radius-pill);
  font-family: var(--font-body);
}

/* Empty spots */
.spots-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 12px;
}

.spot-empty {
  width: 40px;
  height: 40px;
  border: 1.5px dashed var(--border);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  color: var(--border);
  transition: all var(--ease);
  cursor: pointer;
}

.spot-empty:hover {
  border-color: var(--ink);
  color: var(--ink);
  background: var(--acid);
}

/* ── MAP PREVIEW ── */
.detail-map {
  height: 240px;
  background:
    linear-gradient(rgba(13,13,13,.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(13,13,13,.03) 1px, transparent 1px);
  background-size: 32px 32px;
  background-color: #eceae3;
  border: 1.5px solid var(--ink);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 12px;
  position: relative;
  overflow: hidden;
}

.detail-map-pin {
  font-size: 36px;
  filter: drop-shadow(0 4px 8px rgba(0,0,0,.2));
}

.detail-map-label {
  font-size: 13px;
  color: var(--muted);
  font-weight: 300;
}

.detail-map-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12px;
}

.detail-map-address {
  font-size: 13px;
  color: var(--muted);
  font-weight: 300;
}

/* ── COMMENTS SECTION ── */
.comments-list {
  display: flex;
  flex-direction: column;
  gap: 20px;
  margin-bottom: 24px;
}

.comment {
  display: flex;
  gap: 12px;
  align-items: flex-start;
}

.comment-avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  font-weight: 600;
  color: white;
  text-transform: uppercase;
  flex-shrink: 0;
  border: 1.5px solid var(--border);
}

.comment-body { flex: 1; }

.comment-header {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 6px;
}

.comment-name {
  font-size: 13px;
  font-weight: 600;
  color: var(--ink);
  font-family: var(--font-body);
}

.comment-time {
  font-size: 11px;
  color: var(--muted);
  font-weight: 300;
  font-family: var(--font-body);
}

.comment-text {
  font-size: 14px;
  color: var(--muted);
  font-weight: 300;
  line-height: 1.65;
}

/* Comment input */
.comment-form {
  display: flex;
  gap: 12px;
  align-items: flex-start;
}

.comment-input-wrap { flex: 1; }


.comment-input {
  width: 100%;
  padding: 11px 14px;
  border: 1.5px solid var(--border);
  border-radius: var(--radius-sm);
  font-size: 14px;
  font-family: var(--font-body);
  resize: none;
  outline: none;
  transition: border-color var(--ease);
  background: var(--white);
  color: var(--ink);
  min-height: 80px;
}

.comment-input:focus { border-color: var(--ink); }

.comment-input::placeholder { 
    color: var(--muted); 
    font-weight: 300; 
}

/* ── RIGHT COLUMN — sticky action card ── */
.detail-right {
  position: sticky;
  top: calc(var(--nav-h) + 24px);
  display: flex;
  flex-direction: column;
  gap: 16px;
}

/* Action card */
.detail-action-card {
  background: var(--white);
  border: 2px solid var(--ink);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

.action-card-header {
  background: var(--ink);
  padding: 20px 24px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.action-card-spots {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 36px;
  letter-spacing: -1px;
  color: var(--acid);
  line-height: 1;
}

.action-card-spots-label {
  font-size: 12px;
  color: rgba(245,242,235,.5);
  font-weight: 300;
  margin-top: 4px;
  font-family: var(--font-body);
}

/* Capacity progress bar */
.capacity-bar {
  height: 4px;
  background: rgba(245,242,235,.15);
  border-radius: 2px;
  overflow: hidden;
  margin-top: 12px;
}

.capacity-fill {
  height: 100%;
  background: var(--acid);
  border-radius: 2px;
  transition: width .5s ease;
}

.action-card-body {
  padding: 20px 24px;
  display: flex;
  flex-direction: column;
  gap: 14px;
}

/* Host info inside action card */
.action-host {
  display: flex;
  align-items: center;
  gap: 12px;
  padding-bottom: 14px;
  border-bottom: 1px solid var(--border);
}

.action-host-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: var(--ink);
  color: var(--acid);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 600;
  flex-shrink: 0;
}

.action-host-label {
  font-size: 11px;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: .06em;
  font-weight: 600;
  font-family: var(--font-body);
}

.action-host-name {
  font-size: 14px;
  font-weight: 500;
  color: var(--ink);
  font-family: var(--font-body);
}

/* Quick info rows */
.action-info-row {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 13px;
  font-family: var(--font-body);
}

.action-info-icon { 
    font-size: 15px; 
    flex-shrink: 0; 
}

.action-info-label { 
    color: var(--muted); 
    font-weight: 300; 
    flex: 1; 
}

.action-info-value { 
    color: var(--ink); 
    font-weight: 500; 
    text-align: right; 
}

/* Join button */
.action-join-btn {
  width: 100%;
  padding: 16px;
  background: var(--acid);
  border: 2px solid var(--ink);
  border-radius: var(--radius-sm);
  font-family: var(--font-display);
  font-size: 20px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: -.3px;
  color: var(--ink);
  cursor: pointer;
  transition: all var(--ease);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
}

.action-join-btn:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-sm);
}

.action-join-btn.joined {
  background: var(--ink);
  color: var(--acid);
}

.action-join-btn:disabled {
  background: var(--border);
  border-color: var(--border);
  color: var(--muted);
  cursor: not-allowed;
  transform: none;
  box-shadow: none;
}

.action-share {
  display: flex;
  gap: 8px;
}

.action-share-btn {
  flex: 1;
  padding: 10px;
  border: 1.5px solid var(--border);
  border-radius: var(--radius-sm);
  font-size: 13px;
  font-weight: 500;
  color: var(--muted);
  text-align: center;
  cursor: pointer;
  transition: all var(--ease);
  background: transparent;
  font-family: var(--font-body);
}

.action-share-btn:hover { 
    border-color: var(--ink); 
    color: var(--ink); 
}

/* Similar events */
.similar-events {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.similar-event-row {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px;
  background: var(--white);
  border: 1.5px solid var(--border);
  border-radius: var(--radius-sm);
  cursor: pointer;
  transition: all var(--ease);
  text-decoration: none;
  color: inherit;
}

.similar-event-row:hover { 
    border-color: var(--ink); 
    transform: translateX(3px); 
}

.similar-icon { 
    font-size: 20px; 
    flex-shrink: 0; 
}

.similar-info { 
    flex: 1; 
    min-width: 0; 
}

.similar-title {
  font-size: 13px;
  font-weight: 500;
  color: var(--ink);
  font-family: var(--font-body);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.similar-meta {
  font-size: 11px;
  color: var(--muted);
  font-weight: 300;
  font-family: var(--font-body);
}

/* ── RESPONSIVE ── */
@media (max-width: 1024px) {
  .detail-body {
    grid-template-columns: 1fr 320px;
    gap: 40px;
  }
}

@media (max-width: 768px) {
  .detail-hero { padding: 32px var(--side-pad) 0; }
  .detail-hero::before { display: none; }
  .detail-title { font-size: clamp(32px, 8vw, 56px); }
  .detail-meta-strip { gap: 16px; }
 
  .detail-body {
    grid-template-columns: 1fr;
    padding: 32px var(--side-pad) 48px;
    gap: 40px;
  }
 
  .detail-right {
    position: static;
    order: -1;
  }
}
</file>

<file path="frontend/css/pages/explore.css">
/* PAGE LAYOUT */

.explore-page {
  padding-top: var(--nav-h);
  min-height: 100vh;
}

/* ── HERO SEARCH BAR ── */
.explore-hero {
  background: var(--ink);
  padding: 48px var(--side-pad);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24px;
  position: relative;
  overflow: hidden;
}

/* Large background letter */
.explore-hero::before {
  content: 'FIND';
  position: absolute;
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 280px;
  line-height: 1;
  color: rgba(255,255,255,.03);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
  user-select: none;
  white-space: nowrap;
}

.explore-hero-title {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: clamp(32px, 4vw, 52px);
  text-transform: uppercase;
  letter-spacing: -1px;
  color: var(--dark-text);
  text-align: center;
  line-height: 1;
}

.explore-hero-title span { 
    color: var(--acid); 
}

/* Main search bar */
.explore-search-bar {
  width: 100%;
  max-width: 680px;
  display: flex;
  align-items: center;
  background: var(--white);
  border: 2px solid var(--white);
  border-radius: var(--radius-pill);
  overflow: hidden;
  box-shadow: var(--shadow-lg);
  transition: border-color var(--ease);
}

.explore-search-bar:focus-within {
  border-color: var(--acid);
}

.explore-search-icon {
  padding: 0 16px 0 20px;
  font-size: 18px;
  flex-shrink: 0;
  color: var(--muted);
}

.explore-search-input {
  flex: 1;
  padding: 16px 0;
  border: none;
  outline: none;
  font-size: 16px;
  font-family: var(--font-body);
  font-weight: 400;
  color: var(--ink);
  background: transparent;
}

.explore-search-input::placeholder { 
    color: var(--muted); 
}

.explore-search-divider {
  width: 1px;
  height: 28px;
  background: var(--border);
  flex-shrink: 0;
}

.explore-search-location {
  padding: 16px 16px;
  border: none;
  outline: none;
  font-size: 14px;
  font-family: var(--font-body);
  color: var(--muted);
  background: transparent;
  width: 160px;
  flex-shrink: 0;
}

.explore-search-btn {
  background: var(--acid);
  border: none;
  padding: 12px 24px;
  font-family: var(--font-display);
  font-size: 18px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .05em;
  color: var(--ink);
  cursor: pointer;
  transition: background var(--ease);
  flex-shrink: 0;
  margin: 4px;
  border-radius: var(--radius-pill);
}

.explore-search-btn:hover { 
    background: #d4ff1a; 
}

.explore-quick-tags {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
  justify-content: center;
}

.explore-quick-label {
  font-size: 12px;
  color: rgba(245,242,235,.4);
  font-weight: 300;
}

.explore-quick-tag {
  padding: 5px 14px;
  border: 1px solid rgba(245,242,235,.2);
  border-radius: var(--radius-pill);
  font-size: 12px;
  color: rgba(245,242,235,.7);
  cursor: pointer;
  transition: all var(--ease);
  font-family: var(--font-body);
  background: none;
}

.explore-quick-tag:hover {
  background: var(--acid);
  border-color: var(--acid);
  color: var(--ink);
}

/* ── MAIN CONTENT ── */
.explore-main {
  display: grid;
  grid-template-columns: 280px 1fr;
  gap: 0;
  max-width: var(--max-w);
  margin: 0 auto;
  padding: 0 var(--side-pad);
  padding-top: 40px;
  padding-bottom: 80px;
  align-items: start;
}

/* ── FILTERS SIDEBAR ── */
.explore-filters {
  position: sticky;
  top: calc(var(--nav-h) + 16px);
  padding-right: 32px;
}

.filters-title {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 18px;
  text-transform: uppercase;
  letter-spacing: -.3px;
  color: var(--ink);
  margin-bottom: 24px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.filters-reset {
  font-family: var(--font-body);
  font-size: 12px;
  font-weight: 400;
  color: var(--muted);
  text-transform: none;
  letter-spacing: 0;
  cursor: pointer;
  text-decoration: underline;
  text-underline-offset: 2px;
  background: none;
  border: none;
  transition: color var(--ease);
}

.filters-reset:hover { 
    color: var(--ink); 
}

/* Filter group */
.filter-group {
  margin-bottom: 28px;
  padding-bottom: 28px;
  border-bottom: 1px solid var(--border);
}

.filter-group:last-child {
  border-bottom: none;
  margin-bottom: 0;
}

.filter-group-title {
  font-size: 13px;
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 14px;
  text-transform: uppercase;
  letter-spacing: .06em;
  font-family: var(--font-body);
}

/* Checkbox options */
.filter-option {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 6px 0;
  cursor: pointer;
  font-size: 14px;
  color: var(--muted);
  transition: color var(--ease);
  font-family: var(--font-body);
}

.filter-option:hover { 
    color: var(--ink); 
}

.filter-option input[type="checkbox"] {
  width: 16px;
  height: 16px;
  border: 1.5px solid var(--border);
  border-radius: 4px;
  cursor: pointer;
  accent-color: var(--ink);
  flex-shrink: 0;
}

.filter-option-count {
  margin-left: auto;
  font-size: 11px;
  color: var(--muted);
  background: rgba(13,13,13,.06);
  padding: 2px 7px;
  border-radius: var(--radius-pill);
}

/* Distance slider */
.filter-range {
  width: 100%;
  accent-color: var(--ink);
  margin-bottom: 6px;
}

.filter-range-labels {
  display: flex;
  justify-content: space-between;
  font-size: 11px;
  color: var(--muted);
  font-family: var(--font-body);
}

/* ── RESULTS AREA ── */
.explore-results {
  min-width: 0;
}

.results-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24px;
  gap: 16px;
  flex-wrap: wrap;
}

.results-count {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 28px;
  text-transform: uppercase;
  letter-spacing: -.5px;
  color: var(--ink);
}

.results-count span {
  color: var(--muted);
  font-size: 22px;
}

.results-controls {
  display: flex;
  align-items: center;
  gap: 10px;
}

/* Sort select */
.results-sort {
  padding: 8px 14px;
  border: 1.5px solid var(--border);
  border-radius: var(--radius-pill);
  font-size: 13px;
  font-weight: 500;
  color: var(--ink);
  background: var(--paper);
  outline: none;
  cursor: pointer;
  transition: border-color var(--ease);
  font-family: var(--font-body);
}

.results-sort:hover,
.results-sort:focus { 
    border-color: var(--ink); 
}

/* View toggle: grid / list */
.view-toggle {
  display: flex;
  border: 1.5px solid var(--border);
  border-radius: var(--radius-sm);
  overflow: hidden;
}

.view-btn {
  padding: 7px 12px;
  font-size: 14px;
  cursor: pointer;
  transition: all var(--ease);
  border: none;
  background: transparent;
  color: var(--muted);
}

.view-btn.active {
  background: var(--ink);
  color: var(--acid);
}

/* ── EVENT GRID ── */
.events-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 16px;
}

/* Explore event card — full version */
.explore-event-card {
  background: var(--white);
  border: 1.5px solid var(--ink);
  border-radius: var(--radius-md);
  overflow: hidden;
  cursor: pointer;
  transition: transform var(--ease), box-shadow var(--ease);
  display: flex;
  flex-direction: column;
  text-decoration: none;
  color: inherit;
}

.explore-event-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-card);
}

/* Card color band at top */
.explore-event-card-band {
  height: 6px;
  background: var(--acid);
  flex-shrink: 0;
}

.band-football   { background: #3b8f5e; }
.band-basketball { background: #e67e22; }
.band-tennis     { background: #2ecc71; }
.band-running    { background: #e74c3c; }
.band-volleyball { background: #9b59b6; }
.band-cycling    { background: #3498db; }
.band-default    { background: var(--acid); }

.explore-event-card-body {
  padding: 18px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  flex: 1;
}

.explore-event-card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 8px;
}

.explore-event-card-sport {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .06em;
  color: var(--muted);
  font-family: var(--font-body);
}

.explore-event-card-title {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 19px;
  text-transform: uppercase;
  letter-spacing: -.3px;
  color: var(--ink);
  line-height: 1.1;
}

.explore-event-card-meta {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.explore-event-card-meta-row {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  color: var(--muted);
  font-weight: 300;
}

.explore-event-card-meta-icon { 
    font-size: 11px; 
    flex-shrink: 0; 
}

.explore-event-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 12px;
  border-top: 1px solid var(--border);
  margin-top: auto;
}

/* Skill level pill */
.skill-pill {
  display: inline-flex;
  align-items: center;
  padding: 3px 10px;
  border-radius: var(--radius-pill);
  font-size: 10px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: .04em;
  border: 1px solid currentColor;
  font-family: var(--font-body);
}

.skill-all { 
    color: var(--success); 
    background: var(--success-bg); 
}

.skill-beginner { 
    color: var(--info);    
    background: var(--info-bg); 
}

.skill-intermediate { 
    color: var(--warning); 
    background: var(--warning-bg); 
}

.skill-advanced { 
    color: var(--danger);  
    background: var(--danger-bg); 
}

/* ── LIST VIEW (alternative to grid) ── */
.events-list { 
    display: none; 
    flex-direction: 
    column; gap: 10px; 
}

.events-list.active { display: flex; }

.events-grid.active { display: grid; }

.explore-event-list-item {
  background: var(--white);
  border: 1.5px solid var(--border);
  border-radius: var(--radius-md);
  padding: 16px 20px;
  display: flex;
  align-items: center;
  gap: 20px;
  cursor: pointer;
  transition: all var(--ease);
  text-decoration: none;
  color: inherit;
}

.explore-event-list-item:hover {
  border-color: var(--ink);
  transform: translateX(4px);
}

.list-item-sport-icon { 
    font-size: 24px; 
    flex-shrink: 0; 
}

.list-item-body { 
    flex: 1; 
    min-width: 0; 
}

.list-item-title {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 18px;
  text-transform: uppercase;
  letter-spacing: -.3px;
  color: var(--ink);
  margin-bottom: 4px;
}

.list-item-meta {
  font-size: 12px;
  color: var(--muted);
  font-weight: 300;
}

.list-item-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6px;
  flex-shrink: 0;
}

/* ── NO RESULTS ── */
.no-results {
  grid-column: 1 / -1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80px 24px;
  gap: 16px;
  text-align: center;
}

.no-results-icon { 
    font-size: 48px; 
    opacity: .3; 
}

.no-results-title {
  font-family: var(--font-display);
  font-size: 28px;
  font-weight: 800;
  text-transform: uppercase;
  color: var(--ink);
}

.no-results-desc { 
    font-size: 14px; 
    color: var(--muted); 
    font-weight: 300; 
}

/* ── RESPONSIVE ── */
@media (max-width: 1024px) {
  .explore-main { grid-template-columns: 240px 1fr; }
}

@media (max-width: 768px) {
  .explore-hero { padding: 32px var(--side-pad); }
  .explore-search-location { display: none; }
  .explore-search-divider { display: none; }
 
  .explore-main {
    grid-template-columns: 1fr;
    padding-top: 24px;
  }
 
  .explore-filters {
    position: static;
    padding-right: 0;
    display: none;
  }
  .explore-filters.open { display: block; }
 
  .events-grid {
    grid-template-columns: 1fr;
  }
}
</file>

<file path="frontend/css/pages/landing.css">
/* ---------------------HERO0---------------------- */

.hero {
  padding-top: calc(var(--nav-h) + 80px);
  padding-bottom: 80px;
  padding-left: var(--side-pad);
  padding-right: var(--side-pad);
  max-width: var(--max-w);
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: center;
}

/* Eyebrow line above the title */

.hero-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  font-weight: 500;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 20px;
  font-family: var(--font-body);
}

.hero-eyebrow-tag {
  background: var(--acid);
  border: 1px solid var(--ink);
  border-radius: var(--radius-pill);
  padding: 3px 10px;
  color: var(--ink);
  font-weight: 600;
}

.hero-title {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: clamp(64px, 7vw, 96px);
  line-height: .92;
  letter-spacing: -2px;
  text-transform: uppercase;
  margin-bottom: 24px;
  color: var(--ink);
}

.hero-title em {
  font-style: normal;
  color: var(--muted);
}

/* Description  */
.hero-desc {
  font-size: 17px;
  line-height: 1.65;
  color: var(--muted);
  max-width: 420px;
  margin-bottom: 36px;
  font-weight: 300;
}

/* CTA buttons row */
.hero-actions {
  display: flex;
  align-items: center;
  gap: 14px;
  flex-wrap: wrap;
}

.hero-note {
  font-size: 12px;
  color: var(--muted);
  margin-top: 16px;
  font-weight: 300;
}


/* HERO ANIMATIONS */

.hero-eyebrow { animation: fadeUp .5s .00s ease both; }

.hero-title   { animation: fadeUp .6s .10s ease both; }

.hero-desc    { animation: fadeUp .6s .20s ease both; }

.hero-actions { animation: fadeUp .6s .30s ease both; }

.hero-visual  { animation: fadeUp .7s .20s ease both; }


/* HERO CARD STACK */

.hero-visual {
  position: relative;
}

.event-card-stack {
  position: relative;
  height: 420px;
}

/* Base card in stack */

.stack-card {
  position: absolute;
  background: var(--white);
  border: 1.5px solid var(--ink);
  border-radius: 18px;
  padding: 24px;
  width: 280px;
  transition: transform var(--ease);
}

.stack-card:hover { 
    transform: translateY(-4px); 
}

.stack-card-main   { 
    top: 20px; 
    left: 20px; 
    z-index: 3; 
    box-shadow: var(--shadow-card); 
}

.stack-card-mid    { 
    top: 60px; 
    left: 60px; 
    z-index: 2; 
    background: var(--acid); box-shadow: var(--shadow-sm); 
}

.stack-card-back   { 
    top: 100px; 
    left: 100px; 
    z-index: 1; 
    background: #e8e4de; 
    box-shadow: 3px 3px 0 var(--ink); 
}

/* Sport badge inside stack cards */

.stack-card-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: var(--acid);
  border: 1px solid var(--ink);
  border-radius: var(--radius-pill);
  padding: 4px 12px;
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: .06em;
  margin-bottom: 14px;
}

.stack-card-mid .stack-card-badge { 
    background: var(--white); 
}

.stack-card-title {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 20px;
  line-height: 1.1;
  margin-bottom: 8px;
  text-transform: uppercase;
  color: var(--ink);
}

.stack-card-meta {
  font-size: 12px;
  color: var(--muted);
  margin-bottom: 16px;
  line-height: 1.7;
  font-weight: 300;
}

.stack-card-mid .stack-card-meta { 
    color: rgba(13,13,13,.6); 
}

.stack-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* Join button inside stack card */
.stack-join-btn {
  background: var(--ink);
  color: var(--acid);
  border-radius: var(--radius-pill);
  padding: 6px 14px;
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
  border: none;
  transition: all var(--ease);
  font-family: var(--font-body);
}

.stack-join-btn:hover { 
    background: #2a2a2a; 
    transform: scale(1.04); 
}


/* STATS STRIP */

.stats-strip {
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  padding: 28px var(--side-pad);
  display: flex;
  justify-content: center;
  gap: 80px;
}

.stat {
  text-align: center;
}

.stat-num {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 42px;
  line-height: 1;
  letter-spacing: -1px;
  color: var(--ink);
}

.stat-label {
  font-size: 12px;
  color: var(--muted);
  letter-spacing: .06em;
  text-transform: uppercase;
  margin-top: 4px;
  font-family: var(--font-body);
}

/* GRID */

.steps-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  border: 1.5px solid var(--ink);
  border-radius: 18px;
  overflow: hidden;
}

.step {
  padding: 40px 32px;
  border-right: 1.5px solid var(--ink);
  transition: background var(--ease);
}


.step:last-child { 
    border-right: none; 
}

.step:hover { 
    background: var(--acid); 
}

.step-num {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 80px;
  line-height: 1;
  color: rgba(13,13,13,.08);
  margin-bottom: 16px;
  transition: color var(--ease);
}

.step:hover .step-num { 
    color: rgba(13,13,13,.15); 
}

.step-title {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 26px;
  text-transform: uppercase;
  letter-spacing: -.5px;
  margin-bottom: 10px;
  color: var(--ink);
}

.step-desc {
  font-size: 14px;
  line-height: 1.65;
  color: var(--muted);
  font-weight: 300;
  transition: color var(--ease);
}

.step:hover .step-desc { 
    color: rgba(13,13,13,.6); 
}

/* ---------------SPORTS SECTION - DARK BACKGROUND -------- */

.sports-section {
  background: var(--dark-bg);
  color: var(--dark-text);
  padding: 80px var(--side-pad);
}

.sports-section .section-label { 
    color: rgba(245,242,235,.4); 
}

.sports-section .section-title { 
    color: var(--dark-text); 
}

.sports-scroll {
  display: flex;
  gap: 12px;
  overflow-x: auto;
  padding-bottom: 16px;
  scrollbar-width: none;
}

.sports-scroll::-webkit-scrollbar { 
    display: none; 
}

.sport-chip {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 18px 24px;
  border: 1px solid rgba(245,242,235,.15);
  border-radius: var(--radius-pill);
  cursor: pointer;
  transition: all var(--ease);
  white-space: nowrap;
  color: var(--dark-text);
}

.sport-chip:hover {
  background: var(--acid);
  border-color: var(--acid);
  color: var(--ink);
}

.sport-icon {
  font-size: 20px;
  line-height: 1;
}

.sport-name {
  font-family: var(--font-display);
  font-size: 18px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: .05em;
}

.sport-count {
  font-size: 12px;
  color: rgba(245,242,235,.4);
  margin-left: auto;
  padding-left: 8px;
  transition: color var(--ease);
}

.sport-chip:hover .sport-count { 
    color: rgba(13,13,13,.5); 
}


/* -------------------CTA BANNER ------------------------- */

.cta-banner {
  margin: 80px auto;
  max-width: calc(var(--max-w) - 96px);
  background: var(--acid);
  border: 2px solid var(--ink);
  border-radius: 24px;
  padding: 64px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 40px;
  box-shadow: var(--shadow-lg);
}

.cta-banner-title {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: clamp(36px, 4vw, 56px);
  text-transform: uppercase;
  letter-spacing: -1px;
  line-height: 1;
  max-width: 520px;
  color: var(--ink);
}


.cta-banner-actions {
  display: flex;
  flex-direction: column;
  gap: 12px;
  align-items: flex-start;
  flex-shrink: 0;
}


/*------------------------ RESPONSIVE---------------------------- */

@media (max-width: 1024px) {
  .hero { gap: 40px; }
  .stats-strip { gap: 40px; }
}

@media (max-width: 768px) {
  .hero {
    grid-template-columns: 1fr;
    padding-top: calc(var(--nav-h) + 48px);
    padding-bottom: 48px;
    gap: 40px;
  }

  .hero-visual { 
    display: none; 
}
 
  .stats-strip {
    gap: 24px;
    flex-wrap: wrap;
    padding: 24px var(--side-pad);
  }
 
  .steps-grid {
    grid-template-columns: 1fr;
    border-radius: var(--radius-md);
  }

  .step {
    border-right: none;
    border-bottom: 1.5px solid var(--ink);
  }

  .step:last-child { border-bottom: none; }
 
  .sports-section { padding: 60px var(--side-pad); }
 
  .cta-banner {
    flex-direction: column;
    padding: 40px 28px;
    margin: 40px var(--side-pad);
  }
  
  .cta-banner-actions { width: 100%; }
  .cta-banner-actions .btn { width: 100%; justify-content: center; }
}
</file>

<file path="frontend/css/pages/my-events.css">
/* ============================================================
   MY-EVENTS.CSS — My Events page styles
   SportSpot · requires base.css + components.css
   ============================================================ */

/* ── PAGE LAYOUT ── */
.my-events-page {
  padding-top: 64px;
  min-height: 100vh;
  max-width: 1200px;
  margin: 0 auto;
  padding-left: 48px;
  padding-right: 48px;
  padding-bottom: 80px;
}

/* ── PAGE HEADER ── */
.my-events-header {
  padding: 48px 0 32px;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 24px;
  border-bottom: 1px solid rgba(13,13,13,.14);
}

.my-events-heading {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 800;
  font-size: clamp(40px, 5vw, 64px);
  text-transform: uppercase;
  letter-spacing: -1px;
  line-height: 1;
  color: #0d0d0d;
}
.my-events-heading span { color: #6b6b5e; }

.my-events-header-actions {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-shrink: 0;
}

/* ── STATS ROW ── */
.my-events-stats {
  display: flex;
  gap: 0;
  border: 1.5px solid #0d0d0d;
  border-radius: 14px;
  overflow: hidden;
  margin: 32px 0;
}

.my-stat {
  flex: 1;
  padding: 20px 24px;
  border-right: 1.5px solid #0d0d0d;
  text-align: center;
  transition: background .2s ease;
}
.my-stat:last-child { border-right: none; }
.my-stat:hover { background: #c8ff00; }

.my-stat-num {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 800;
  font-size: 36px;
  letter-spacing: -1px;
  line-height: 1;
  color: #0d0d0d;
  margin-bottom: 4px;
}
.my-stat-label {
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: .08em;
  color: #6b6b5e;
  font-family: 'DM Sans', sans-serif;
}

/* ── TABS ── */
.my-events-tabs {
  display: flex;
  gap: 0;
  border-bottom: 1.5px solid rgba(13,13,13,.14);
  margin-bottom: 32px;
}

.my-tab {
  padding: 14px 24px;
  font-size: 14px;
  font-weight: 500;
  color: #6b6b5e;
  cursor: pointer;
  border: none;
  background: none;
  border-bottom: 2.5px solid transparent;
  margin-bottom: -1.5px;
  transition: all .2s ease;
  font-family: 'DM Sans', sans-serif;
  display: flex;
  align-items: center;
  gap: 8px;
}
.my-tab:hover { color: #0d0d0d; }
.my-tab.active {
  color: #0d0d0d;
  border-bottom-color: #0d0d0d;
}

.my-tab-count {
  background: rgba(13,13,13,.14);
  border-radius: 100px;
  padding: 2px 8px;
  font-size: 11px;
  font-weight: 600;
  color: #6b6b5e;
  transition: all .2s ease;
}
.my-tab.active .my-tab-count {
  background: #0d0d0d;
  color: #c8ff00;
}

/* ── TAB PANELS ── */
.my-tab-panel { display: none; }
.my-tab-panel.active {
  display: block;
  animation: fadeIn .25s ease both;
}

/* ── EVENT ROW ── */
/* IMPORTANT: NO overflow:hidden here — it was clipping the manage dropdown */
.my-event-row {
  display: grid;
  grid-template-columns: 6px 1fr auto;
  gap: 0;
  background: #ffffff;
  border: 1.5px solid rgba(13,13,13,.14);
  border-radius: 14px;
  /* overflow: hidden  ← REMOVED — was clipping the dropdown */
  margin-bottom: 12px;
  transition: all .2s ease;
  cursor: pointer;
  position: relative; /* needed so dropdown stacks correctly */
}
.my-event-row:hover {
  border-color: #0d0d0d;
  transform: translateX(4px);
  box-shadow: 3px 3px 0 #0d0d0d;
}

/* Left color strip — needs border-radius on left side since row has no overflow:hidden */
.my-event-strip {
  background: #c8ff00;
  border-radius: 12px 0 0 12px; /* match row radius on left side only */
}
.strip-football   { background: #3b8f5e; }
.strip-basketball { background: #e67e22; }
.strip-tennis     { background: #2ecc71; }
.strip-running    { background: #e74c3c; }
.strip-volleyball { background: #9b59b6; }
.strip-cycling    { background: #3498db; }
.strip-default    { background: #c8ff00; }

/* Main content of row */
.my-event-body {
  padding: 18px 20px;
  display: flex;
  align-items: center;
  gap: 20px;
  min-width: 0;
}

.my-event-icon { font-size: 28px; flex-shrink: 0; }
.my-event-info { flex: 1; min-width: 0; }

.my-event-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 700;
  font-size: 19px;
  text-transform: uppercase;
  letter-spacing: -.3px;
  color: #0d0d0d;
  margin-bottom: 4px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.my-event-meta {
  display: flex;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
}
.my-event-meta-item {
  font-size: 12px;
  color: #6b6b5e;
  font-weight: 300;
  display: flex;
  align-items: center;
  gap: 4px;
  font-family: 'DM Sans', sans-serif;
}

/* Right side actions */
.my-event-actions {
  padding: 18px 20px;
  display: flex;
  align-items: center;
  gap: 10px;
  flex-shrink: 0;
  border-left: 1px solid rgba(13,13,13,.14);
  position: relative; /* anchor for the dropdown */
}

/* ── SECTION HEADERS ── */
.my-section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
  margin-top: 8px;
}
.my-section-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 700;
  font-size: 14px;
  text-transform: uppercase;
  letter-spacing: .08em;
  color: #6b6b5e;
}

/* ── EMPTY STATE ── */
.my-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 64px 24px;
  gap: 16px;
  border: 1.5px dashed rgba(13,13,13,.14);
  border-radius: 14px;
}
.my-empty-icon { font-size: 48px; opacity: .25; }
.my-empty-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 800;
  font-size: 24px;
  text-transform: uppercase;
  color: #0d0d0d;
}
.my-empty-desc {
  font-size: 14px;
  color: #6b6b5e;
  font-weight: 300;
  max-width: 280px;
  line-height: 1.65;
}

/* ── MANAGE DROPDOWN ── */
.manage-menu {
  position: relative;
  display: inline-block;
}

.manage-dropdown {
  display: none;
  position: absolute;
  right: 0;
  top: calc(100% + 6px);
  background: #ffffff;
  border: 1.5px solid #0d0d0d;
  border-radius: 8px;
  box-shadow: 3px 3px 0 #0d0d0d;
  min-width: 180px;
  z-index: 100;
}
.manage-menu.open .manage-dropdown {
  display: block;
  animation: fadeIn .15s ease both;
}

.manage-item {
  display: block;
  width: 100%;
  padding: 10px 16px;
  font-size: 13px;
  font-weight: 400;
  color: #0d0d0d;
  text-align: left;
  cursor: pointer;
  transition: background .2s ease;
  border: none;
  background: none;
  font-family: 'DM Sans', sans-serif;
  border-bottom: 1px solid rgba(13,13,13,.14);
}
.manage-item:last-child { border-bottom: none; }
.manage-item:hover { background: #c8ff00; }
.manage-item.danger { color: #b53030; }
.manage-item.danger:hover { background: #fdeaea; }

/* When dropdown is open, add bottom padding to the row
   so the dropdown doesn't overlap the event below it.
   4 items × 41px each + 6px gap from button = ~170px */
.my-event-row:has(.manage-menu.open) {
  padding-bottom: 175px;
  transition: padding-bottom .15s ease;
}

/* ── RESPONSIVE ── */
@media (max-width: 768px) {
  .my-events-page {
    padding-left: 20px;
    padding-right: 20px;
  }
  .my-events-header {
    flex-direction: column;
    align-items: flex-start;
    padding: 32px 0 24px;
  }
  .my-events-stats { flex-wrap: wrap; }
  .my-stat {
    flex: 1 1 40%;
    border-bottom: 1.5px solid #0d0d0d;
  }
  .my-event-body { gap: 12px; }
  .my-event-icon { display: none; }
  .my-event-actions { padding: 12px; }
  .my-tab { padding: 12px 16px; font-size: 13px; }
}
</file>

<file path="frontend/css/pages/profile.css">
/* Profile Page Layout */
.profile-page {
    position: relative;
    padding-bottom: 60px;
    background-color: var(--color-bg);
}

.profile-banner {
    width: 100%;
    height: 200px;
    background: linear-gradient(120deg, var(--color-primary), #6366f1);
    border-radius: 0 0 24px 24px;
}

.profile-container {
    max-width: 1200px;
    margin: -100px auto 0;
    padding: 0 20px;
    display: flex;
    gap: 40px;
    align-items: flex-start;
}

/* Sidebar Info Card */
.profile-sidebar {
    width: 320px;
    flex-shrink: 0;
}

.profile-card {
    background: var(--color-surface);
    border-radius: 20px;
    padding: 30px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.05);
    text-align: center;
}

.profile-image-wrapper {
    position: relative;
    width: 140px;
    height: 140px;
    margin: 0 auto 20px;
}

.profile-img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid var(--color-surface);
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
}

.profile-img.placeholder {
    background: #e2e8f0;
    display: flex;
    align-items: center;
    justify-content: center;
}

.profile-name {
    font-size: 24px;
    font-weight: 700;
    margin-bottom: 5px;
    color: var(--color-text);
}

.profile-location {
    color: var(--color-text-light);
    font-size: 14px;
    margin-bottom: 25px;
}

/* Stats */
.profile-stats {
    display: flex;
    justify-content: center;
    gap: 40px;
    padding-bottom: 25px;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 25px;
}

.stat-box {
    display: flex;
    flex-direction: column;
    align-items: center;
}

.stat-value {
    font-size: 22px;
    font-weight: 700;
    color: var(--color-text);
}

.stat-label {
    font-size: 12px;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-top: 5px;
}

/* Bio */
.profile-bio-section {
    text-align: left;
    margin-bottom: 25px;
}

.profile-bio-section h4 {
    font-size: 14px;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 10px;
}

.profile-bio {
    font-size: 15px;
    line-height: 1.5;
    color: var(--color-text);
}

.profile-actions .btn {
    width: 100%;
    border-radius: 12px;
}

/* Main Feed */
.profile-feed {
    flex-grow: 1;
    margin-top: 100px; /* Offset the banner overlap from sidebar */
}

.profile-tabs {
    display: flex;
    gap: 15px;
    margin-bottom: 30px;
}

.tab-btn {
    background: none;
    border: none;
    padding: 10px 20px;
    font-size: 16px;
    font-weight: 600;
    color: var(--color-text-light);
    cursor: pointer;
    border-radius: 20px;
    transition: all 0.2s ease;
}

.tab-btn:hover {
    color: var(--color-text);
    background: var(--color-bg-hover);
}

.tab-btn.active {
    background: var(--color-text);
    color: var(--color-surface);
}

.event-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
}

/* Modal styles (Edit Profile) */
.modal {
    display: none;
    position: fixed;
    z-index: 1000;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0,0,0,0.4);
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(4px);
}

.modal.show {
    display: flex;
}

.modal-content {
    background-color: var(--color-surface);
    padding: 30px;
    border-radius: 20px;
    width: 100%;
    max-width: 500px;
    position: relative;
    box-shadow: 0 15px 40px rgba(0,0,0,0.15);
}

.close-btn {
    position: absolute;
    top: 20px;
    right: 25px;
    font-size: 24px;
    font-weight: normal;
    cursor: pointer;
    color: var(--color-text-light);
}

.close-btn:hover {
    color: var(--color-text);
}

.form-group {
    margin-bottom: 20px;
}

.form-group label {
    display: block;
    margin-bottom: 8px;
    font-weight: 600;
    color: var(--color-text);
}

.form-control {
    width: 100%;
    padding: 12px 15px;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    font-size: 15px;
    transition: border-color 0.2s;
    outline: none;
    box-sizing: border-box;
}

.form-control:focus {
    border-color: var(--color-primary);
}

.modal-actions {
    display: flex;
    gap: 15px;
    margin-top: 30px;
}

/* Responsive */
@media (max-width: 900px) {
    .profile-container {
        flex-direction: column;
        align-items: center;
        margin-top: -60px;
    }

    .profile-sidebar {
        width: 100%;
        max-width: 400px;
    }

    .profile-feed {
        margin-top: 0;
        width: 100%;
    }
}
</file>


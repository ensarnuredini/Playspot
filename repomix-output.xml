        r = requests.post(f"{BASE_URL}/api/JoinRequest/{self.event_id}",
                          headers=auth_headers(self.token_b))
        assert r.status_code == 400

    def test_invalid_event_id(self):
        r = requests.post(f"{BASE_URL}/api/JoinRequest/99999",
